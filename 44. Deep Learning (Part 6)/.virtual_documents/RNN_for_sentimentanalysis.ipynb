


import pandas as pd
import re
import nltk
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords





df = pd.read_csv("IMDB Dataset.csv")


df.shape


df.head()





df.isnull().sum()


df.drop_duplicates(inplace = True)


df.shape








df["review"] = df["review"].str.lower()





